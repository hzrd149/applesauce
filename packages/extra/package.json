{
  "name": "applesauce-extra",
  "version": "6.2.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./concord": {
      "import": "./dist/concord/index.js",
      "require": "./dist/concord/index.js",
      "types": "./dist/concord/index.d.ts"
    },
    "./concord/*": {
      "import": "./dist/concord/*.js",
      "require": "./dist/concord/*.js",
      "types": "./dist/concord/*.d.ts"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "watch:build": "tsc --watch > /dev/null",
    "test": "vitest run --passWithNoTests",
    "watch:test": "vitest"
  },
  "keywords": [
    "nostr",
    "applesauce",
    "vertex",
    "primal"
  ],
  "author": "hzrd149",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "applesauce-core": "^6.2.0",
    "rxjs": "^7.8.2"
  },
  "optionalDependencies": {
    "applesauce-common": "^6.2.0",
    "applesauce-relay": "^6.2.0",
    "applesauce-signers": "^6.2.0"
  },
  "devDependencies": {
    "@hirez_io/observer-spy": "^2.2.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.15"
  },
  "funding": {
    "type": "lightning",
    "url": "lightning:nostrudel@geyser.fund"
  }
}
